{
  "name": "agentsec-app",
  "version": "0.1.1",
  "description": "AgentSec desktop client — local AI agent security scanner (Electron + React)",
  "author": "ChuhC (https://github.com/ChuhC)",
  "homepage": "https://github.com/ChuhC/AgentSec",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChuhC/AgentSec.git"
  },
  "bugs": {
    "url": "https://github.com/ChuhC/AgentSec/issues"
  },
  "license": "AGPL-3.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "dependencies": {
    "electron-updater": "^6.6.2",
    "reactflow": "^11.11.4"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "screenshots": "node scripts/capture-readme-screenshots.mjs",
    "build:engine": "node ../scripts/build-engine.cjs",
    "dist:mac": "electron-builder --mac dmg --publish never",
    "dist:win": "electron-builder --win nsis --publish never",
    "dist": "npm run dist:mac"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^40.10.5",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "dev.agentsec.app",
    "productName": "AgentSec",
    "icon": "build/icon.icns",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "generateUpdatesFilesForAllChannels": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../engine/dist_pkg/agentsec-engine",
        "to": "engine"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "win": {
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true
    },
    "publish": {
      "provider": "github",
      "owner": "ChuhC",
      "repo": "AgentSec"
    }
  }
}
